{
    "name": "uflagmey/donationcampaigns",
    "type": "phpbb-extension",
    "description": "Attach donation campaigns to phpBB topics. Administrators record confirmed payments manually; the extension processes no payments.",
    "version": "1.0.0-beta1",
    "keywords": [
        "phpbb",
        "extension",
        "donation",
        "campaign",
        "fundraising"
    ],
    "homepage": "https://github.com/uflagmey/donationcampaigns",
    "license": "GPL-2.0-only",
    "authors": [
        {
            "name": "uflagmey",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^7.2 || ^8.0",
        "composer/installers": "~1.0"
    },
    "require-dev": {
        "phpbb/epv": "dev-master"
    },
    "extra": {
        "display-name": "Donation Campaigns",
        "soft-require": {
            "phpbb/phpbb": ">=3.3.16,<4.0.0@dev"
        }
    }
}
